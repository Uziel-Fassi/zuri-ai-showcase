# =============================================================================
# .env.example — GENIE.AI / ZURI AI Environment Variables
# =============================================================================
# PURPOSE: This file documents ALL required environment variables.
# USAGE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every <placeholder> with your real values.
#   3. NEVER commit your filled-in .env to git. It is already in .gitignore.
#
# TEMPLATE FILES:
#   - env-T4              → template for docker-compose-t4.yaml (CPU/T4 GPU)
#   - api-gateway-solution/env → template for the Kong/Keycloak API gateway
#   Both follow this same convention. Copy and fill locally; never commit.
# =============================================================================


# =============================================================================
# GENERAL
# =============================================================================
LOGFLAG=true
no_proxy=noproxy
http_proxy=
https_proxy=


# =============================================================================
# BACKEND SERVICE (gov-chat-backend / Node.js)
# =============================================================================

# ---- Auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=<your-strong-random-jwt-secret-min-64-chars>
JWT_EXPIRES_IN=24h

# ---- Internal Service Auth ----
# Shared API key for inter-service communication (dataprep, retriever, chatqna, document-repository).
# All services must share the same value. If unset, internal endpoints will be unprotected.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
INTERNAL_API_KEY=<your-strong-random-internal-api-key>

# ---- Sessions ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<your-strong-random-session-secret>
SESSION_EXPIRATION_TIME=1800000

# ---- Server ----
NODE_ENV=production
BACKEND_PORT=3000
API_PREFIX=/api
LOG_LEVEL=info
UV_THREADPOOL_SIZE=128
CORS_ORIGIN=http://localhost/
FRONTEND_URL=http://localhost:8090

# ---- Email (Mailjet / SMTP) ----
EMAIL_HOST=<your-smtp-host>
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=<your-smtp-api-key-or-username>
EMAIL_PASSWORD=<your-smtp-password>
EMAIL_FROM=noreply@<your-domain>

# ---- File storage ----
UPLOAD_DIR=./Uploads
MAX_FILE_SIZE=5242880
BACKUP_DIR=./database_backups
MAX_BACKUPS=5
BACKUP_FORMAT=json
COMPRESS_BACKUPS=true

# ---- Misc ----
APP_NAME=Genie AI
OPEA_HOST=chatqna-xeon-backend-server
OPEA_PORT=8888
OPENWEATHERMAP_API_KEY=<your-openweathermap-api-key>
CONTEXT_OPTION=conversation-with-context-labels


# =============================================================================
# ARANGODB
# =============================================================================
ARANGO_URL=http://arango-vector-db:8529
ARANGO_PORT=8529
ARANGO_DB_NAME=genie-ai
ARANGO_DB=node-services
ARANGO_USER=root
# Set a strong password. Must match the password you configure on the ArangoDB container.
ARANGO_PASSWORD=<your-arangodb-root-password>
MAX_SOCKETS=100
MAX_FREE_SOCKETS=50


# =============================================================================
# REDIS CACHE (Translation cache)
# =============================================================================
TRANSLATION_CACHE=on
TRANSLATION_CACHE_HOST=redis-cache
TRANSLATION_CACHE_PORT=6379
TRANSLATION_CACHE_PATH=/cache/translations
TRANSLATION_CACHE_PASSWORD=<your-redis-password>
TRANSLATION_THREADS=4
TRANSLATION_BATCHES=5


# =============================================================================
# FRONTEND SERVICE (gov-chat-frontend / Vue.js)
# =============================================================================
FRONTEND_PORT=8090
VUE_APP_API_URL=https://<your-domain-or-localhost>/api
VUE_PROXY_HOST=kong:8010
# Content Security Policy — add your domain(s) to connect-src
VUE_APP_CSP_CONNECT_SRC="'self' http://localhost https://localhost ws://localhost wss://localhost http://localhost:3000 http://localhost:8090 https://localhost:8090"
CSP_CONNECT_SRC="'self' http://localhost https://localhost ws://localhost:8090 wss://localhost:8090"
CORS_ALLOWED_ORIGINS=http://localhost,https://localhost,http://localhost:3000,http://localhost:8090


# =============================================================================
# KONG DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_USER=kong
POSTGRES_DB=kong
POSTGRES_PASSWORD=<your-kong-db-password>
KONG_DATABASE=postgres
KONG_PG_HOST=kong-database
KONG_PG_USER=kong
KONG_PG_PASSWORD=<your-kong-db-password>
KONG_PROXY_ACCESS_LOG=/dev/stdout
KONG_ADMIN_ACCESS_LOG=/dev/stdout
KONG_PROXY_ERROR_LOG=/dev/stderr
KONG_ADMIN_ERROR_LOG=/dev/stderr
KONG_ADMIN_LISTEN=0.0.0.0:8001, 0.0.0.0:8444 ssl
KONG_DNS_RESOLVER=127.0.0.11
KONG_DNS_ORDER=LAST,A,AAAA,CNAME


# =============================================================================
# KONGA (Kong Admin UI)
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=<your-konga-token-secret>
DB_ADAPTER=mongo
DB_HOST=mongo
DB_PORT=27017
DB_DATABASE=konga
DB_USER=
DB_PASSWORD=
KONGA_HOOK_TIMEOUT=120000
KONG_ADMIN_URL=http://kong:8001
KONGA_LOG_LEVEL=warn


# =============================================================================
# KEYCLOAK
# =============================================================================
KC_DB=postgres
KC_DB_URL_HOST=keycloak-db
KC_DB_URL_DATABASE=keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=<your-keycloak-admin-password>
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=<your-keycloak-db-password>
KC_HTTP_ENABLED=true
KC_HOSTNAME=localhost
KC_HTTP_PORT=8080

# Keycloak PostgreSQL
# Note: this POSTGRES_DB/USER/PASSWORD section is used by the keycloak-db service.
# If you run Kong and Keycloak in the same compose, use different variable names
# or separate compose files to avoid collision.
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
# POSTGRES_PASSWORD=<your-keycloak-db-password>  (set this in api-gateway-solution/.env, not here)


# =============================================================================
# DOCUMENT REPOSITORY SERVICE
# =============================================================================
DOC_REPO_PORT=3001
DOCUMENT_INGESTION_LANGUAGE=en,es
DATAPREP_HOST=http://dataprep-arango-service
DATAPREP_PORT=5000
MAX_FILES_UPLOAD=10
MAX_FILE_SIZE=52428800
BCRYPT_ROUNDS=10

# ---- Virus scanning (ClamAV) ----
VIRUS_SCANNING=true
CLAMSCAN_REMOVE_INFECTED=false
CLAMSCAN_QUARANTINE_INFECTED=false
CLAMSCAN_DEBUG_MODE=false
CLAMSCAN_SOCKET=false
CLAMSCAN_HOST=127.0.0.1
CLAMSCAN_PORT=3310
CLAMSCAN_TIMEOUT=60000
CLAMSCAN_LOCAL_FALLBACK=true
CLAMSCAN_PATH=/usr/bin/clamdscan
CLAMSCAN_ACTIVE=true


# =============================================================================
# EXTERNAL AI / ML KEYS
# =============================================================================

# HuggingFace — required to pull gated models (e.g. meta-llama, bge-*)
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=<your-huggingface-api-token>
HUGGING_FACE_HUB_TOKEN=<your-huggingface-api-token>

# Google Gemini (used via LiteLLM gemini-adapter)
GEMINI_API_KEY=<your-google-gemini-api-key>

# vLLM API key — only needed when connecting to a REMOTE vLLM endpoint.
# Leave blank when running vLLM locally via docker-compose (no auth needed).
VLLM_API_KEY=<your-vllm-api-key-if-using-remote-vllm-endpoint>


# =============================================================================
# CHATQNA PIPELINE (OPEA microservices)
# =============================================================================
OPEA_EXAMPLES_URL=https://github.com/opea-project/GenAIExamples.git
CHATQNA_TYPE=CHATQNA_MACDAVID
MEGA_SERVICE_HOST_IP=chatqna-xeon-backend-server

# Labeler (intent classifier)
LABELER_ENABLED=true
LABELER_MODEL_ID=typeform/distilbert-base-uncased-mnli
LABELER_TIMEOUT_MS=2000
LABELER_CONFIDENCE_THRESHOLD=0.45

# Embedding service
EMBEDDING_SERVER_HOST_IP=tei
EMBEDDING_SERVER_PORT=80

# Retriever service
RETRIEVER_SERVICE_HOST_IP=retriever-arango-service
RETRIEVER_SERVICE_PORT=7025

# Reranker service
RERANK_SERVER_HOST_IP=tei_reranker
RERANK_SERVER_PORT=80
RERANKER_TOP_N=3

# LLM service
LLM_SERVER_HOST_IP=vllm
LLM_SERVER_PORT=8000

# Guardrail service
GUARDRAIL_SERVICE_HOST_IP=guardrail
GUARDRAIL_SERVICE_PORT=9090

# Translation service
TRANSLATION_SERVICE_HOST_IP=vllm-translation-guardrail
TRANSLATION_SERVICE_PORT=9030

# Document repository
DOC_REPO_URL=http://document-repository:3001


# =============================================================================
# STT SERVICE (Whisper)
# =============================================================================
STT_PORT=8005
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=es


# =============================================================================
# CHATQNA NGINX PROXY
# =============================================================================
NGINX_PORT=80
FRONTEND_SERVICE_IP=chatqna-xeon-ui-server
FRONTEND_SERVICE_PORT=5173
BACKEND_SERVICE_NAME=chatqna
BACKEND_SERVICE_IP=chatqna-xeon-backend-server
BACKEND_SERVICE_PORT=8888
DATAPREP_SERVICE_IP=dataprep-arango-service
DATAPREP_SERVICE_PORT=5000


# =============================================================================
# CRAWLER
# =============================================================================
CRAWLER_POLL_INTERVAL_MS=5000
CRAWLER_MAX_PAGES=5000
CRAWLER_WORKER_CONCURRENCY=10
LOG_FILE=app.log
